    {
      "name": "08 - Flujo POS (orden sugerido)",
      "description": "Ejecutar en orden con Collection Runner.",
      "item": [
        {
          "name": "1. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.token) {",
                  "        pm.collectionVariables.set('token', json.token);",
                  "        try { pm.environment.set('token', json.token); } catch (e) {}",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "2. Listar métodos de pago",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/metodos-pago"
          }
        },
        {
          "name": "3. Abrir arqueo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.body && json.body.id_arqueo) {",
                  "        pm.collectionVariables.set('id_arqueo', json.body.id_arqueo);",
                  "        try { pm.environment.set('id_arqueo', json.body.id_arqueo); } catch (e) {}",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto_apertura\": 100000,\n  \"observacion\": \"Inicio de turno\"\n}"
            },
            "url": "{{base_url}}/arqueos/abrir"
          }
        },
        {
          "name": "4. Venta en efectivo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_cliente\": {{id_cliente}},\n  \"detalle\": [\n    { \"id_producto\": {{id_producto}}, \"cantidad\": 1 }\n  ],\n  \"pagos\": [\n    { \"metodo_pago\": \"EFECTIVO\", \"monto\": 18000 }\n  ]\n}"
            },
            "url": "{{base_url}}/ventas/crear"
          }
        },
        {
          "name": "5. Venta por Nequi",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"detalle\": [\n    { \"id_producto\": {{id_producto}}, \"cantidad\": 1 }\n  ],\n  \"pagos\": [\n    {\n      \"metodo_pago\": \"NEQUI\",\n      \"monto\": 18000,\n      \"referencia\": \"M12345678\"\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/ventas/crear"
          }
        },
        {
          "name": "6. Ver movimientos inventario",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/movimientos-inventario"
          }
        },
        {
          "name": "7. Cerrar arqueo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto_cierre_real\": 118000,\n  \"observacion\": \"Fin de turno\"\n}"
            },
            "url": "{{base_url}}/arqueos/{{id_arqueo}}/cerrar",
            "description": "118000 = 100000 apertura + 18000 venta efectivo (Nequi no suma al efectivo físico)."
          }
        },
        {
          "name": "8. Ver auditoría del arqueo",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auditoria?id_arqueo={{id_arqueo}}"
          }
        }
      ]
    }
